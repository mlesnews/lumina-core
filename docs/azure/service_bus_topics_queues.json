    },
    "topics": [
      {
        "name": "jarvis.workflows",
        "description": "Workflow-related messages for JARVIS system",
        "max_size_in_megabytes": 1024,
        "default_message_time_to_live": "P7D",
        "duplicate_detection_history_time_window": "PT1M",
        "enable_batched_operations": true,
        "enable_partitioning": false,
        "subscriptions": [
          {
            "name": "workflow-processor",
            "max_delivery_count": 10,
            "lock_duration": "PT60S",
            "default_message_time_to_live": "P7D",
            "dead_letter_on_message_expiration": true,
            "enable_batched_operations": true,
            "filter": {
              "type": "SqlFilter",
              "expression": "MessageType = 'WorkflowCreated' OR MessageType = 'WorkflowExecutionRequest'"
            }
          },
          {
            "name": "workflow-notifications",
            "max_delivery_count": 5,
            "lock_duration": "PT60S",
            "default_message_time_to_live": "P7D",
            "dead_letter_on_message_expiration": true,
            "enable_batched_operations": true,
            "filter": {
              "type": "SqlFilter",
              "expression": "MessageType = 'WorkflowStatusUpdate' OR MessageType = 'WorkflowCompleted'"
            }
          },
          {
            "name": "workflow-audit",
            "max_delivery_count": 1,
            "lock_duration": "PT60S",
            "default_message_time_to_live": "P30D",
            "dead_letter_on_message_expiration": false,
            "enable_batched_operations": true,
            "filter": {
              "type": "TrueFilter"
            }
          }
        ]
      },
